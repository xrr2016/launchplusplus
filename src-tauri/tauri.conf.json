{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Launch++",
  "version": "../package.json",
  "identifier": "cn.coldstoneboy.launchplusplus",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "启动加加",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyQkQ4OERGRURGOTgxNzkKUldSNWdmbnQzNGk5c2thWExoSW1sWU1RMkhWMjB1dzRjYUFqalBBbytMVXdoVzNmeTdGd3dKazQK",
      "endpoints": [
        "https://github.com/xrr2016/launchplusplus/releases/latest/download/latest.json"
      ]
    }
  }
}
